# UAE PASS credentials (sandbox values from docs.uaepass.ae — replace with your own)
UAE_PASS_ENV=staging
UAE_PASS_CLIENT_ID=sandbox_stage
UAE_PASS_CLIENT_SECRET=sandbox_stage
UAE_PASS_REDIRECT_URI=http://localhost:3000/callback

# Used to sign session cookies and PKCE verifier store (any 32+ char random string)
SESSION_SECRET=change-me-to-a-32-char-random-secret
